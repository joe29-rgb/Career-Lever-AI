                                <Input
                                  type="month"
                                  placeholder="End Date"
                                  value={project.endDate}
                                  onChange={(e) => updateProject(project.id, 'endDate', e.target.value)}
                                />
                              </div>
                            </div>

                            <div className="space-y-4">
                              <Textarea
                                placeholder="Project description and your role..."
