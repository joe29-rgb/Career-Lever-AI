                                  <Button
                                    type="button"
                                    size="sm"
                                    variant="outline"
                                    onClick={() => {
                                      const input = document.querySelector(`input[placeholder="Add technology"]`) as HTMLInputElement
                                      if (input?.value) {
                                        addProjectTechnology(project.id, input.value)
                                        input.value = ''
